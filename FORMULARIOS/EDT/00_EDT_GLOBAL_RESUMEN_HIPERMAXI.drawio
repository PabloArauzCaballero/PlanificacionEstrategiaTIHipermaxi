<?xml version="1.0" encoding="UTF-8"?><mxfile host="app.diagrams.net" modified="2026-07-01T20:32:18Z" agent="ChatGPT" version="24.7.17" type="device"><diagram id="1ab5d9199106" name="Resumen global"><mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2100" pageHeight="1450" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="EDT GLOBAL — Estrategia Integral de Tecnologías de Información para la Modernización Operativa de HIPERMAXI&lt;br&gt;&lt;span style='font-size:12px'&gt;Resumen ejecutivo por entregables: qué recibe HIPERMAXI en cada elemento&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=18;fillColor=#062B24;strokeColor=#062B24;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="2020" height="75" as="geometry"/></mxCell><mxCell id="root" value="PROYECTO&lt;br&gt;&lt;span style='font-size:11px'&gt;Estrategia Integral de Tecnologías de Información para la Modernización Operativa de HIPERMAXI&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=15;fillColor=#F9FAFB;strokeColor=#111827;fontColor=#111827;shadow=1;" vertex="1" parent="1"><mxGeometry x="560" y="130" width="980" height="60" as="geometry"/></mxCell><mxCell id="comp_cloud" value="&lt;div style='font-size:16px'&gt;&lt;b&gt;1.0 CLOUD&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:10px;margin-top:6px'&gt;&lt;b&gt;Resultado:&lt;/b&gt; HIPERMAXI recibe una plataforma cloud contratada, segura, operable, respaldada y preparada para ambientes de desarrollo, pruebas, preproducción y producción.&lt;/div&gt;&lt;div style='font-size:10px;margin-top:8px'&gt;&lt;b&gt;Entregables:&lt;/b&gt;&lt;br&gt;1.1 Contrato de asesoría cloud aprobado&lt;br&gt;1.2 Servicios cloud contratados y cuenta operativa&lt;br&gt;1.3 Plan de respaldo y continuidad configurado&lt;br&gt;1.4 Ambientes cloud configurados&lt;br&gt;1.5 Servicios cloud base habilitados&lt;br&gt;1.6 Seguridad y operación cloud implementadas&lt;br&gt;1.7 Manuales y capacitación cloud entregados&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#EAF3FF;strokeColor=#0B5CAD;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="60" y="240" width="360" height="460" as="geometry"/></mxCell><mxCell id="tag_cloud" value="1.0" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#0B5CAD;strokeColor=#0B5CAD;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="345" y="250" width="55" height="24" as="geometry"/></mxCell><mxCell id="comp_adq" value="&lt;div style='font-size:16px'&gt;&lt;b&gt;2.0 ADQUISICIONES&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:10px;margin-top:6px'&gt;&lt;b&gt;Resultado:&lt;/b&gt; HIPERMAXI recibe proveedores evaluados, compras justificadas, materiales adquiridos y control documental de recepción, garantías e inventario.&lt;/div&gt;&lt;div style='font-size:10px;margin-top:8px'&gt;&lt;b&gt;Entregables:&lt;/b&gt;&lt;br&gt;2.1 Matriz de cotización de proveedores&lt;br&gt;2.2 Proveedores económicamente factibles seleccionados&lt;br&gt;2.3 Materiales y recursos adquiridos&lt;br&gt;2.4 Control de activos, garantías y capacitación de recepción&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#FFF6E3;strokeColor=#8A5A00;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="470" y="240" width="360" height="460" as="geometry"/></mxCell><mxCell id="tag_adq" value="2.0" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#8A5A00;strokeColor=#8A5A00;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="755" y="250" width="55" height="24" as="geometry"/></mxCell><mxCell id="comp_redes" value="&lt;div style='font-size:16px'&gt;&lt;b&gt;3.0 REDES&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:10px;margin-top:6px'&gt;&lt;b&gt;Resultado:&lt;/b&gt; HIPERMAXI recibe conectividad estable y segura entre tienda, operación administrativa, invitados, cajas/POS y nube, con documentación as-built y pruebas de desempeño.&lt;/div&gt;&lt;div style='font-size:10px;margin-top:8px'&gt;&lt;b&gt;Entregables:&lt;/b&gt;&lt;br&gt;3.1 Experto en redes contratado&lt;br&gt;3.2 Servicios de conectividad contratados&lt;br&gt;3.3 Personal operativo de red contratado/asignado&lt;br&gt;3.4 Terreno preparado para red&lt;br&gt;3.5 Switches, router y dispositivos de red instalados&lt;br&gt;3.6 Puntos de acceso instalados&lt;br&gt;3.7 Cableado estructurado implementado&lt;br&gt;3.8 VPN sucursal-cloud configurada&lt;br&gt;3.9 Seguridad de red implementada&lt;br&gt;3.10 Pruebas y documentación as-built&lt;br&gt;3.11 Manuales y capacitación de operación de red&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#E7F7F5;strokeColor=#0B6B63;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="880" y="240" width="360" height="460" as="geometry"/></mxCell><mxCell id="tag_redes" value="3.0" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#0B6B63;strokeColor=#0B6B63;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="1165" y="250" width="55" height="24" as="geometry"/></mxCell><mxCell id="comp_infra" value="&lt;div style='font-size:16px'&gt;&lt;b&gt;4.0 INFRAESTRUCTURA&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:10px;margin-top:6px'&gt;&lt;b&gt;Resultado:&lt;/b&gt; HIPERMAXI recibe áreas técnicas preparadas, equipamiento instalado, energía protegida, activos ordenados, continuidad local y soporte operativo definido.&lt;/div&gt;&lt;div style='font-size:10px;margin-top:8px'&gt;&lt;b&gt;Entregables:&lt;/b&gt;&lt;br&gt;4.1 Experto en infraestructura contratado&lt;br&gt;4.2 Personal de preparación contratado/asignado&lt;br&gt;4.3 Terreno y áreas técnicas preparadas&lt;br&gt;4.4 Racks y gabinetes instalados&lt;br&gt;4.5 UPS y protección eléctrica instaladas&lt;br&gt;4.6 Etiquetado y ordenamiento implementados&lt;br&gt;4.7 Equipamiento de tienda, POS, almacén y oficina instalado&lt;br&gt;4.8 Respaldo local y continuidad implementados&lt;br&gt;4.9 Seguridad física de TI instalada&lt;br&gt;4.10 Plan de mantenimiento, mesa de ayuda y escalamiento&lt;br&gt;4.11 Manuales y capacitación de infraestructura&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#F2ECFF;strokeColor=#5B3A8E;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="1290" y="240" width="360" height="460" as="geometry"/></mxCell><mxCell id="tag_infra" value="4.0" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#5B3A8E;strokeColor=#5B3A8E;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="1575" y="250" width="55" height="24" as="geometry"/></mxCell><mxCell id="comp_soft" value="&lt;div style='font-size:16px'&gt;&lt;b&gt;5.0 SOFTWARE&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:10px;margin-top:6px'&gt;&lt;b&gt;Resultado:&lt;/b&gt; HIPERMAXI recibe un sistema operativo funcional, documentado, probado y aceptado por áreas usuarias para ventas, inventario, compras, gestión, datos y reportes.&lt;/div&gt;&lt;div style='font-size:10px;margin-top:8px'&gt;&lt;b&gt;Entregables:&lt;/b&gt;&lt;br&gt;5.1 Diseño funcional y técnico aprobado&lt;br&gt;5.2 Módulos de operación implementados&lt;br&gt;5.3 Módulos de gestión implementados&lt;br&gt;5.4 Datos migrados y depurados&lt;br&gt;5.5 Documentación técnica entregada&lt;br&gt;5.6 Pruebas, capacitación y manuales aprobados&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#FFF0F3;strokeColor=#9B1C31;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="1700" y="240" width="360" height="460" as="geometry"/></mxCell><mxCell id="tag_soft" value="5.0" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#9B1C31;strokeColor=#9B1C31;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="1985" y="250" width="55" height="24" as="geometry"/></mxCell><mxCell id="road_title" value="Ruta vendible de implementación para el cliente" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=15;fillColor=#083B2D;strokeColor=#083B2D;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="60" y="760" width="1980" height="40" as="geometry"/></mxCell><mxCell id="road0" value="&lt;b&gt;Fase 1&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:12px'&gt;Contrataciones y decisiones base&lt;/span&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Asesorías, proveedores, servicios cloud/conectividad y personal clave aprobados.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=11;fillColor=#FFFFFF;strokeColor=#083B2D;fontColor=#111827;shadow=1;" vertex="1" parent="1"><mxGeometry x="60" y="830" width="360" height="130" as="geometry"/></mxCell><mxCell id="road1" value="&lt;b&gt;Fase 2&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:12px'&gt;Preparación física y técnica&lt;/span&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Terreno, racks, energía, red, ambientes cloud y servicios base listos.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=11;fillColor=#FFFFFF;strokeColor=#083B2D;fontColor=#111827;shadow=1;" vertex="1" parent="1"><mxGeometry x="460" y="830" width="360" height="130" as="geometry"/></mxCell><mxCell id="arr1" value="➜" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=26;fillColor=none;strokeColor=none;fontColor=#374151;shadow=0;" vertex="1" parent="1"><mxGeometry x="405" y="865" width="45" height="45" as="geometry"/></mxCell><mxCell id="road2" value="&lt;b&gt;Fase 3&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:12px'&gt;Implementación operativa&lt;/span&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Software, POS, inventario, compras, equipos y conectividad cloud-sucursal funcionando.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=11;fillColor=#FFFFFF;strokeColor=#083B2D;fontColor=#111827;shadow=1;" vertex="1" parent="1"><mxGeometry x="860" y="830" width="360" height="130" as="geometry"/></mxCell><mxCell id="arr2" value="➜" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=26;fillColor=none;strokeColor=none;fontColor=#374151;shadow=0;" vertex="1" parent="1"><mxGeometry x="805" y="865" width="45" height="45" as="geometry"/></mxCell><mxCell id="road3" value="&lt;b&gt;Fase 4&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:12px'&gt;Seguridad, pruebas y continuidad&lt;/span&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Backups, VPN, firewalls, VLAN, pruebas de latencia/failover y UAT aprobados.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=11;fillColor=#FFFFFF;strokeColor=#083B2D;fontColor=#111827;shadow=1;" vertex="1" parent="1"><mxGeometry x="1260" y="830" width="360" height="130" as="geometry"/></mxCell><mxCell id="arr3" value="➜" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=26;fillColor=none;strokeColor=none;fontColor=#374151;shadow=0;" vertex="1" parent="1"><mxGeometry x="1205" y="865" width="45" height="45" as="geometry"/></mxCell><mxCell id="road4" value="&lt;b&gt;Fase 5&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:12px'&gt;Transferencia y cierre&lt;/span&gt;&lt;br&gt;&lt;span style='font-size:10px'&gt;Manuales, capacitación, mesa de ayuda, escalamiento y actas de aceptación final.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=11;fillColor=#FFFFFF;strokeColor=#083B2D;fontColor=#111827;shadow=1;" vertex="1" parent="1"><mxGeometry x="1660" y="830" width="360" height="130" as="geometry"/></mxCell><mxCell id="arr4" value="➜" style="rounded=0;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=26;fillColor=none;strokeColor=none;fontColor=#374151;shadow=0;" vertex="1" parent="1"><mxGeometry x="1605" y="865" width="45" height="45" as="geometry"/></mxCell><mxCell id="summary" value="&lt;b&gt;Cierre global esperado:&lt;/b&gt; HIPERMAXI debe recibir una plataforma cloud segura, compras trazables, red operativa, infraestructura física protegida y software probado/capacitado. Cada elemento se cierra con evidencia, manuales, capacitación y acta de aceptación." style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=13;fillColor=#ECFFF8;strokeColor=#083B2D;fontColor=#111827;shadow=1;spacing=12;" vertex="1" parent="1"><mxGeometry x="60" y="1030" width="1980" height="90" as="geometry"/></mxCell><mxCell id="files" value="Archivos individuales incluidos: 01 Cloud, 02 Adquisiciones, 03 Redes, 04 Infraestructura y 05 Software. Este archivo es el resumen global para presentación ejecutiva." style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=10;fillColor=#F9FAFB;strokeColor=#D1D5DB;fontColor=#374151;shadow=0;" vertex="1" parent="1"><mxGeometry x="60" y="1160" width="1980" height="55" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>