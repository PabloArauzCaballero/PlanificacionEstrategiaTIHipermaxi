<?xml version="1.0" encoding="UTF-8"?><mxfile host="app.diagrams.net" modified="2026-07-01T20:32:18Z" agent="ChatGPT" version="24.7.17" type="device"><diagram id="9a49ab40441d" name="EDT por entregables"><mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1150" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="2.0 ADQUISICIONES — Estrategia Integral de Tecnologías de Información para la Modernización Operativa de HIPERMAXI&lt;br&gt;&lt;span style='font-size:12px'&gt;EDT / WBS por entregables aceptables para el cliente&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=18;fillColor=#062B24;strokeColor=#062B24;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="40" y="30" width="1720" height="70" as="geometry"/></mxCell><mxCell id="root_project" value="PROYECTO&lt;br&gt;&lt;span style='font-size:11px'&gt;Estrategia Integral de Tecnologías de Información para la Modernización Operativa de HIPERMAXI&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=15;fillColor=#F9FAFB;strokeColor=#111827;fontColor=#111827;shadow=1;" vertex="1" parent="1"><mxGeometry x="420" y="130" width="960" height="60" as="geometry"/></mxCell><mxCell id="comp" value="2.0 ADQUISICIONES&lt;br&gt;&lt;span style='font-size:11px'&gt;Resultado vendible: HIPERMAXI recibe proveedores evaluados, compras justificadas, materiales adquiridos y control documental de recepción, garantías e inventario.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=16;fillColor=#8A5A00;strokeColor=#8A5A00;fontColor=#FFFFFF;shadow=1;" vertex="1" parent="1"><mxGeometry x="320" y="220" width="1160" height="90" as="geometry"/></mxCell><mxCell id="e_root_comp" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6B7280;strokeWidth=1.5;endArrow=block;endFill=1;" edge="1" parent="1" source="root_project" target="comp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="legend" value="Jerarquía visual: Proyecto → Componente → Entregables aceptables por HIPERMAXI. Cada entregable incluye subentregables, hito y criterio de aceptación." style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=10;fillColor=#F9FAFB;strokeColor=#D1D5DB;fontColor=#374151;shadow=0;" vertex="1" parent="1"><mxGeometry x="60" y="1060" width="1680" height="45" as="geometry"/></mxCell><mxCell id="d0" value="&lt;div style='font-size:14px;'&gt;&lt;b&gt;2.1 Matriz de cotización de proveedores&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; comparativo formal de proveedores por precio, plazo, garantía, soporte y cumplimiento técnico&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Subentregables:&lt;/b&gt; solicitudes de cotización, fichas técnicas, cuadro comparativo y observaciones de riesgo&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Hito:&lt;/b&gt; cotizaciones completas para decisión de compra&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Aceptación:&lt;/b&gt; mínimo de proveedores evaluados y matriz aprobada por compras/TI&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#FFF6E3;strokeColor=#8A5A00;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="80" y="360" width="780" height="245" as="geometry"/></mxCell><mxCell id="tag0" value="2.1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#8A5A00;strokeColor=#8A5A00;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="790" y="368" width="55" height="24" as="geometry"/></mxCell><mxCell id="d1" value="&lt;div style='font-size:14px;'&gt;&lt;b&gt;2.2 Proveedores económicamente factibles seleccionados&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; proveedores recomendados y justificación de selección económica/técnica&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Subentregables:&lt;/b&gt; ranking de proveedores, análisis costo-beneficio, recomendación y acta de selección&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Hito:&lt;/b&gt; proveedor adjudicado por cada familia de compra&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Aceptación:&lt;/b&gt; firma de autorización de compra y validación presupuestaria&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#FFF6E3;strokeColor=#8A5A00;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="930" y="360" width="780" height="245" as="geometry"/></mxCell><mxCell id="tag1" value="2.2" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#8A5A00;strokeColor=#8A5A00;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="1640" y="368" width="55" height="24" as="geometry"/></mxCell><mxCell id="d2" value="&lt;div style='font-size:14px;'&gt;&lt;b&gt;2.3 Materiales y recursos adquiridos&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; materiales, equipos, herramientas, repuestos y accesorios necesarios para ejecución&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Subentregables:&lt;/b&gt; órdenes de compra, facturas, actas de recepción, garantías y estado de entrega&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Hito:&lt;/b&gt; materiales disponibles para redes, infraestructura, cloud y software&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Aceptación:&lt;/b&gt; recepción física/documental sin observaciones críticas&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#FFF6E3;strokeColor=#8A5A00;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="80" y="645" width="780" height="245" as="geometry"/></mxCell><mxCell id="tag2" value="2.3" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#8A5A00;strokeColor=#8A5A00;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="790" y="653" width="55" height="24" as="geometry"/></mxCell><mxCell id="d3" value="&lt;div style='font-size:14px;'&gt;&lt;b&gt;2.4 Control de activos, garantías y capacitación de recepción&lt;/b&gt;&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; catálogo de activos adquiridos, garantías registradas y procedimiento de recepción/uso&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Subentregables:&lt;/b&gt; inventario inicial, codificación, custodios, manual de recepción, guía de garantía y capacitación a compras/almacén/TI&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Hito:&lt;/b&gt; activos controlados antes de instalación&lt;/div&gt;&lt;div style='font-size:11px;margin-top:4px;'&gt;&lt;b&gt;Aceptación:&lt;/b&gt; inventario conciliado con órdenes de compra y personal capacitado&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#FFF6E3;strokeColor=#8A5A00;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1"><mxGeometry x="930" y="645" width="780" height="245" as="geometry"/></mxCell><mxCell id="tag3" value="2.4" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#8A5A00;strokeColor=#8A5A00;fontColor=#FFFFFF;shadow=0;" vertex="1" parent="1"><mxGeometry x="1640" y="653" width="55" height="24" as="geometry"/></mxC