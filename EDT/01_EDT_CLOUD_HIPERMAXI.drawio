        <mxCell id="tag2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#0B5CAD;strokeColor=#0B5CAD;fontColor=#FFFFFF;shadow=0;" value="1.3" vertex="1">
          <mxGeometry height="24" width="55" x="790" y="653" as="geometry" />
