        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontSize=10;fillColor=#F9FAFB;strokeColor=#D1D5DB;fontColor=#374151;shadow=0;" value="Jerarquía visual: Proyecto → Componente → Entregables aceptables por HIPERMAXI. Cada entregable incluye subentregables, hito y criterio de aceptación." vertex="1">
          <mxGeometry height="45" width="1680" x="60" y="1510" as="geometry" />
        </mxCell>
        <mxCell id="d0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#EAF3FF;strokeColor=#0B5CAD;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" value="&lt;div style=&#39;font-size:14px;&#39;&gt;&lt;b&gt;1.1 Contrato de asesoría cloud aprobado&lt;/b&gt;&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; asesor cloud seleccionado, alcance de asesoría, calendario de acompañamiento y matriz de responsabilidades&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Subentregables:&lt;/b&gt; términos de referencia, contrato/orden de servicio, acta de inicio y criterios técnicos de evaluación&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Hito:&lt;/b&gt; asesor cloud oficialmente incorporado al proyecto&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Aceptación:&lt;/b&gt; firma del patrocinador TI y disponibilidad del asesor para decisiones de arquitectura y costos&lt;/div&gt;" vertex="1">
          <mxGeometry height="245" width="780" x="80" y="360" as="geometry" />
        </mxCell>
        <mxCell id="tag0" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#0B5CAD;strokeColor=#0B5CAD;fontColor=#FFFFFF;shadow=0;" value="1.1" vertex="1">
          <mxGeometry height="24" width="55" x="790" y="368" as="geometry" />
        </mxCell>
        <mxCell id="d1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#EAF3FF;strokeColor=#0B5CAD;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" value="&lt;div style=&#39;font-size:14px;&#39;&gt;&lt;b&gt;1.2 Servicios cloud contratados y cuenta operativa&lt;/b&gt;&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; proveedor cloud contratado, cuenta corporativa activa, facturación configurada y SLA documentado&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Subentregables:&lt;/b&gt; comparativo proveedor, contrato, cuenta tenant/proyecto, usuarios iniciales y centro de costos&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Hito:&lt;/b&gt; servicio cloud disponible para configuración técnica&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Aceptación:&lt;/b&gt; acceso administrativo validado y contrato/facturación aprobados por administración&lt;/div&gt;" vertex="1">
          <mxGeometry height="245" width="780" x="930" y="360" as="geometry" />
        </mxCell>
        <mxCell id="tag1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#0B5CAD;strokeColor=#0B5CAD;fontColor=#FFFFFF;shadow=0;" value="1.2" vertex="1">
          <mxGeometry height="24" width="55" x="1640" y="368" as="geometry" />
        </mxCell>
        <mxCell id="d2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#EAF3FF;strokeColor=#0B5CAD;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" value="&lt;div style=&#39;font-size:14px;&#39;&gt;&lt;b&gt;1.3 Plan de respaldo y continuidad configurado&lt;/b&gt;&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; política de backup, retención, recuperación y continuidad ante falla&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Subentregables:&lt;/b&gt; RPO/RTO definidos, calendario de respaldos, pruebas de restauración y procedimiento de contingencia&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Hito:&lt;/b&gt; primera restauración de prueba ejecutada&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Aceptación:&lt;/b&gt; evidencia de backup/restauración y aprobación del responsable de TI&lt;/div&gt;" vertex="1">
