        <mxCell id="d4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#EAF3FF;strokeColor=#0B5CAD;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" value="&lt;div style=&#39;font-size:14px;&#39;&gt;&lt;b&gt;1.5 Servicios cloud base habilitados&lt;/b&gt;&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; base de datos administrada, almacenamiento de documentos/respaldos y red cloud privada&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Subentregables:&lt;/b&gt; BD administrada, buckets/repositorios, VPC/subredes, reglas mínimas de conexión y documentación técnica&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Hito:&lt;/b&gt; servicios base disponibles para integración con software y sucursales&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Aceptación:&lt;/b&gt; pruebas de conexión, almacenamiento y acceso a base de datos exitosas&lt;/div&gt;" vertex="1">
          <mxGeometry height="245" width="780" x="80" y="930" as="geometry" />
        </mxCell>
        <mxCell id="tag4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;fontStyle=1;fontSize=12;fillColor=#0B5CAD;strokeColor=#0B5CAD;fontColor=#FFFFFF;shadow=0;" value="1.5" vertex="1">
          <mxGeometry height="24" width="55" x="790" y="938" as="geometry" />
        </mxCell>
        <mxCell id="d5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#EAF3FF;strokeColor=#0B5CAD;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" value="&lt;div style=&#39;font-size:14px;&#39;&gt;&lt;b&gt;1.6 Seguridad y operación cloud implementadas&lt;/b&gt;&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; control de usuarios, roles, accesos, monitoreo, logs, alertas y línea base mensual de costos&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Subentregables:&lt;/b&gt; IAM/RBAC, alertas de seguridad, dashboard de operación, presupuesto mensual y alertas de gasto&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Hito:&lt;/b&gt; operación cloud observable y controlada&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Aceptación:&lt;/b&gt; roles probados, alertas activas y reporte mensual de costos aprobado&lt;/div&gt;" vertex="1">
