        <mxCell id="d3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Arial;shadow=1;strokeWidth=1.2;fillColor=#EAF3FF;strokeColor=#0B5CAD;fontColor=#111827;align=left;verticalAlign=top;spacing=12;" value="&lt;div style=&#39;font-size:14px;&#39;&gt;&lt;b&gt;1.4 Ambientes cloud configurados&lt;/b&gt;&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Cliente recibe:&lt;/b&gt; ambientes separados de desarrollo, pruebas, preproducción y producción&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Subentregables:&lt;/b&gt; nomenclatura, accesos, variables, políticas de despliegue y aislamiento por ambiente&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Hito:&lt;/b&gt; ambientes listos para despliegue de software&lt;/div&gt;&lt;div style=&#39;font-size:11px;margin-top:4px;&#39;&gt;&lt;b&gt;Aceptación:&lt;/b&gt; checklist de ambiente validado por equipo técnico y líder de software&lt;/div&gt;" vertex="1">
